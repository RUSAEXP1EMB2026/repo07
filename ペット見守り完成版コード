/**
 * 【画像対応版】Gmailを監視してテキストと写真をLINEへ飛ばす
 */
function checkQwatchAndNotify() {
  // 件名の条件（実際のメールに合わせて変更してください）
  const query = '人感 is:unread'; 
  const threads = GmailApp.search(query);

  if (threads.length === 0) return;

  // iPhone用のApp Storeリンク（必要に応じて変更）
  const cameraUrl = "https://youtube.com/live/YB73KF4pL98?feature=share";

  for (const thread of threads) {
    const messages = thread.getMessages();
    const lastMessage = messages[messages.length - 1];
    const timeStr = Utilities.formatDate(lastMessage.getDate(), "JST", "HH:mm:ss");
    
    // LINEに送るメッセージの配列（リスト）を準備
    let replyMessages = [];

    // ① テキストメッセージをセット
    const messageText = `🚨【Qwatch センサー検知】\n\n人感センサーが反応したワン！🐶\n時刻: ${timeStr}\n\n👇アプリを起動\n${cameraUrl}`;
    replyMessages.push({ 'type': 'text', 'text': messageText });

    // ② 添付ファイル（写真）があれば処理する
    const attachments = lastMessage.getAttachments();
    if (attachments.length > 0) {
      try {
        // 画像をGoogleドライブ（マイドライブの一番上）に保存
        const blob = attachments[0].copyBlob();
        const file = DriveApp.createFile(blob);
        
        // LINEから画像を読み込めるように「リンクを知っている全員」に権限を変更
        file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
        
        // LINE用のダウンロードURLを生成
        const imageUrl = "https://drive.google.com/uc?export=download&id=" + file.getId();
        
        // 画像メッセージをセット
        replyMessages.push({
          'type': 'image',
          'originalContentUrl': imageUrl,
          'previewImageUrl': imageUrl
        });
      } catch (e) {
        console.error("画像処理エラー: " + e.message);
      }
    }

    // LINEに一括送信（テキスト＋画像の2件が同時に送られます）
    sendLineBroadcastAdvanced(replyMessages);
    
    // 既読にする
    thread.markRead();
  }
}

