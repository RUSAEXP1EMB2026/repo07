/**
 * LINEからの受信（Webhook）
 */
function doPost(e) {
  if (typeof e === 'undefined') {
    console.log("エディタから実行されました。テスト用データを使います。");
    e = { postData: { contents: JSON.stringify({ events: [] }) } };
  }
  const event = JSON.parse(e.postData.contents).events[0];
  const replyToken = event.replyToken;
  const userMsg = event.message.text;
  let messageText = "";

  // 1. 温度設定（「温度 28」や数字のみに対応）
  if (userMsg.includes("温度") || (!isNaN(userMsg) && userMsg !== "")) {
    const tempValue = userMsg.replace(/[^0-9.]/g, ""); 
    if (tempValue) {
      updateSettings('temp', tempValue);
      messageText = `設定温度を ${tempValue}℃ に更新したワン！`;
    }
  } 
  // 2. 湿度設定（「湿度 60」に対応）
  else if (userMsg.includes("湿度")) {
    const humiValue = userMsg.replace(/[^0-9.]/g, "");
    if (humiValue) {
      updateSettings('humi', humiValue);
      messageText = `設定湿度を ${humiValue}% に更新したワン！`;
    }
  } 
  // 3. 状態確認
  else if (userMsg === "今の状態" || userMsg === "不快指数") {
    messageText = generateStatusMessage();
  } 
  else {
    messageText = `「今の状態」と聞くか、「温度 28」や「湿度 60」のように送ってほしいワン！`;
  }

  replyToLine(replyToken, messageText);
}

/**
 * 【自動実行用】1時間に1回、LINEに現在の状態をプッシュ通知する関数
 */
function sendHourlyUpdate() {
  // 状態メッセージを作成
  const messageText = "📢【1時間おきのパトロール報告】\n\n" + generateStatusMessage();

  // LINEの「ブロードキャスト」機能を使って自分（全員）に送信
  const url = 'https://api.line.me/v2/bot/message/broadcast';
