  // 件名が「Qwatch検知」で、まだ読んでいないメールを検索
  const query = 'subject:"Qwatch検知" is:unread';
  const threads = GmailApp.search(query);

  if (threads.length === 0) return; // メールがなければ終了

  // QwatchViewアプリを起動するリンク（iPhone用）
  const cameraUrl = "qwatchview://"; 

  for (const thread of threads) {
    const messages = thread.getMessages();
